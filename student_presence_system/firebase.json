          "appId": "1:19730600238:android:78f52a52cc4cd13a552abf",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "smart-student-system",
          "configurations": {
