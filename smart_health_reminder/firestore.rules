rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User document itself
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /profile/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /medicines/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /appointments/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Owner can write; doctors can update appointment status
        allow write: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null;
      }

      match /checkIns/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Any authenticated user can CREATE a notification for another user
      // (patient books → doctor notified; doctor accepts → patient notified)
      match /adminNotifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Doctor profiles are PUBLIC for all authenticated users (patients browse doctors)
    match /doctorProfiles/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == docId;
    }

    // Shared appointments — readable by participants, writable by authenticated users
    match /appointments/{apptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Usernames collection — anyone can check availability, authenticated users can reserve
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Chat rooms — readable/writable by participants
    match /chatRooms/{roomId} {
      allow read, write: if request.auth != null;

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Prescriptions — readable/writable by authenticated users
    match /prescriptions/{prescId} {
      allow read, write: if request.auth != null;
    }
  }
}
